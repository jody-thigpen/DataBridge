APP_NAME=DataBridge
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# App database (users, orgs, orders, billing metadata, audit logs)
# Development uses remote MariaDB/MySQL — same host pattern as Shoeventory.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=saffhire2_db_app
DB_USERNAME=
# Required: empty value causes "using password: NO" from MariaDB. Use quotes if the password contains # or spaces.
DB_PASSWORD=

# Optional SSL for remote DB (path to CA bundle):
# MYSQL_ATTR_SSL_CA=/path/to/ca.pem

# Secured consumer / PII database (separate DB on same host in dev)
DB_DATA_CONNECTION=data
DB_DATA_DATABASE=saffhire2_db_data
DB_DATA_USERNAME=
DB_DATA_PASSWORD=
# Override only when the data DB moves to a different host:
# DB_DATA_HOST=
# DB_DATA_PORT=

# Optional: seed the initial super admin on `php artisan db:seed`
# SUPER_ADMIN_EMAIL=
# SUPER_ADMIN_NAME="Super Admin"
# SUPER_ADMIN_PASSWORD=

# Optional: demo client organization for local/testing
# DEMO_CLIENT_ORG_NAME="Demo Client Company"
# DEMO_CLIENT_ORG_SLUG=demo-client-co
# DEMO_CLIENT_ADMIN_EMAIL=demo-admin@demo-client.test
# DEMO_CLIENT_ADMIN_NAME="Demo Client Admin"
# DEMO_CLIENT_ADMIN_PASSWORD="DemoClient2026!"

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
